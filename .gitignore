# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Environment / secrets
.env
.env.*
*.pem

# Raw PhysioNet downloads (large)
data/raw/ephnogram/**
data/raw/wrist/**
!data/raw/ephnogram/.gitkeep
!data/raw/wrist/.gitkeep

